<section class="product-page section-{{ section.id }}">
  <div class="product-page__inner">
    <div class="product-page__gallery">
      <div class="product-page__main-media">
        {% if product.featured_image %}
          {{
            product.featured_image
            | image_url: width: 1200
            | image_tag: loading: 'eager', class: 'product-page__img', widths: '600, 900, 1200', sizes: '(min-width: 990px) 42vw, 100vw', alt: product.title
          }}
        {% else %}
          <div class="product-page__main-media--ph" aria-hidden="true"></div>
        {% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="product-page__thumbs">
          {% for image in product.images limit: 7 %}
            <a class="product-page__thumb" href="{{ image | image_url: width: 1200 }}">
              {{
                image
                | image_url: width: 220
                | image_tag: loading: 'lazy', class: 'product-page__thumb-img', widths: '110, 165, 220', sizes: '96px', alt: product.title
              }}
            </a>
          {% endfor %}
        </div>
      {% endif %}
      <p class="product-page__watch">Watch - Apply with a Heatpress</p>
    </div>

    <div class="product-page__info">
      <h1 class="product-page__title">{{ product.title | escape }}</h1>

      <div class="product-page__reviews">
        <span class="product-page__stars" aria-hidden="true">★★★★★</span>
        <span class="product-page__review-count">413 Reviews</span>
        <a href="#reviews" class="product-page__review-link">See reviews summary</a>
      </div>

      <p class="product-page__unit-price">{{ product.price | money }} each at 100 pieces.</p>

      {% if product.description != blank %}
        <div class="product-page__desc rte">{{ product.description }}</div>
      {% endif %}

      <div class="product-page__benefits">
        <span>10-Piece Minimum with Free Shipping</span>
        <span>No Art or Set Up Fees</span>
        <span>Upgrade to 5 Day Rush with 25+ pcs</span>
      </div>

      {% assign checkout_variant = product.first_available_variant | default: product.selected_or_first_available_variant %}
      {% if product.available and checkout_variant and checkout_variant.available %}
      {% form 'product', product, class: 'product-page__form' %}
        {% if checkout_variant %}
          <input type="hidden" name="id" value="{{ checkout_variant.id }}">
        {% endif %}
        <input type="hidden" name="properties[Calculated Unit Price]" value="" data-calc-unit-hidden>
        <input type="hidden" name="properties[Calculated Total]" value="" data-calc-total-hidden>
        <input type="hidden" name="properties[custom_price]" value="" data-calc-custom-price-hidden>
        <input type="hidden" name="properties[Quote Token]" value="" data-calc-quote-token-hidden>
        <input type="hidden" name="properties[Quote API URL]" value="{{ section.settings.quote_api_url | escape }}">
        <input type="hidden" name="properties[AI Provider]" value="fal.ai">
        <input type="hidden" name="properties[AI Model]" value="Flux">
        <input type="hidden" name="properties[AI Prompt]" value="" data-ai-prompt-hidden>
        <input type="hidden" name="properties[AI Request ID]" value="" data-ai-request-hidden>
        <input type="hidden" name="properties[AI Image URL]" value="" data-ai-image-hidden>

        <div class="product-page__upload-card" data-upload-dropzone>
          <div class="product-page__upload-icon" aria-hidden="true">⬆</div>
          <h3 class="product-page__upload-title">Upload your file</h3>
          <p class="product-page__upload-text">Drag and drop file here or click to browse</p>
          <label class="product-page__browse">
            <input
              type="file"
              name="properties[Artwork file]"
              accept=".ai,.eps,.pdf,.png,.jpg,.jpeg,.svg,.psd"
              data-upload-input
            >
            Browse
          </label>
          <p class="product-page__upload-file" data-upload-filename>No file selected</p>
          <p class="product-page__upload-note">Login to see previous designs</p>
        </div>
        <div class="product-page__ai-card">
          <p class="product-page__ai-title">Create a design with Ninja AI</p>
          <p class="product-page__ai-subtitle">
            Unleash your creativity and design your vision effortlessly with Ninja AI
          </p>
          <div class="product-page__ai-actions">
            <button type="button" class="product-page__ai-generate-btn" data-ai-open-modal>Create an Image ✨</button>
          </div>
        </div>

        <div class="cs-modal" data-ai-modal hidden>
          <div class="cs-modal__backdrop" data-ai-close-modal></div>
          <div class="cs-modal__dialog" role="dialog" aria-modal="true" aria-label="Ninja AI Image Creator">

            <div class="cs-modal__left">
              <button type="button" class="cs-modal__close" data-ai-close-modal aria-label="Close">×</button>

              <p class="cs-modal__eyebrow">✏ CREATOR STUDIO</p>
              <h2 class="cs-modal__title">Ninja AI Image Creator</h2>
              <p class="cs-modal__subtitle">Transform your ideas into high-fidelity patch visuals using our advanced neural engine.</p>

              <label class="cs-modal__label">Describe your vision</label>
              <div class="cs-modal__prompt-wrap">
                <textarea
                  class="cs-modal__prompt"
                  data-ai-prompt
                  rows="4"
                  placeholder="An embroidered skull patch, bold outline, black and red, on a dark background..."
                ></textarea>
                <button type="button" class="cs-modal__generate" data-ai-generate>Generate</button>
              </div>
              <p class="cs-modal__status" data-ai-status></p>

              <div class="cs-modal__params-header">
                <span class="cs-modal__params-label">Example Parameters</span>
                <button type="button" class="cs-modal__randomize" data-ai-randomize>↺ Randomize</button>
              </div>
              <div class="cs-modal__tags">
                <span class="cs-modal__tag cs-modal__tag--style">STYLE <strong data-ai-tag-style>Embroidered</strong></span>
                <span class="cs-modal__tag cs-modal__tag--subject">SUBJECT <strong data-ai-tag-subject>Eagle Head</strong></span>
                <span class="cs-modal__tag cs-modal__tag--text">TEXT <strong data-ai-tag-text>NINJA</strong></span>
                <span class="cs-modal__tag cs-modal__tag--bg">BG <strong data-ai-tag-bg>Black</strong></span>
              </div>
              <p class="cs-modal__preview-prompt" data-ai-preview-prompt>
                "A professional embroidered patch of a <em>stylized eagle head</em> with the text <em>NINJA</em> in bold, black background, bold outline, max 4 colors..."
              </p>
            </div>

            <div class="cs-modal__right">
              <div class="cs-modal__result-area" data-ai-results>
                <div class="cs-modal__result-placeholder">
                  <span class="cs-modal__result-placeholder-icon">🖼</span>
                  <p>Your generated image will appear here</p>
                </div>
              </div>
              <div class="cs-modal__result-meta" data-ai-result-meta hidden>
                <span class="cs-modal__result-filename" data-ai-result-filename>Result.png</span>
                <span class="cs-modal__result-res" data-ai-result-res>1024×1024</span>
              </div>
              <button type="button" class="cs-modal__use-btn" data-ai-use-design hidden>
                ✔ USE THIS DESIGN
              </button>
              <p class="cs-modal__powered">Powered by Flux via fal.ai</p>
            </div>

          </div>
        </div>
        <div class="product-page__progress" data-upload-progress hidden>
          <div class="product-page__progress-character" aria-hidden="true">
            <svg class="product-page__ninja-svg" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="ninjaSuit" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#3fd27f"/>
                  <stop offset="100%" stop-color="#1f8d50"/>
                </linearGradient>
                <linearGradient id="ninjaDark" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#1b703e"/>
                  <stop offset="100%" stop-color="#145f34"/>
                </linearGradient>
                <linearGradient id="blade" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#9ea9b2"/>
                  <stop offset="55%" stop-color="#f3f8fc"/>
                  <stop offset="100%" stop-color="#7d8a95"/>
                </linearGradient>
              </defs>
              <ellipse cx="60" cy="106" rx="29" ry="7" fill="rgba(0,0,0,0.22)"/>
              <g class="ninja-svg__character">
                <g class="ninja-svg__sword">
                  <rect x="69" y="38" width="34" height="4.5" rx="2" fill="url(#blade)"/>
                  <circle cx="69" cy="40" r="3.5" fill="#f3a12b"/>
                </g>
                <g class="ninja-svg__leg-left">
                  <rect x="47" y="70" width="12" height="24" rx="6" fill="url(#ninjaDark)"/>
                </g>
                <g class="ninja-svg__leg-right">
                  <rect x="61" y="70" width="12" height="24" rx="6" fill="url(#ninjaDark)"/>
                </g>
                <g class="ninja-svg__body">
                  <rect x="39" y="41" width="42" height="34" rx="14" fill="url(#ninjaSuit)"/>
                  <ellipse cx="60" cy="58" rx="14" ry="9" fill="rgba(255,255,255,0.16)"/>
                </g>
                <g class="ninja-svg__arm-left">
                  <rect x="32" y="47" width="10" height="24" rx="5" fill="url(#ninjaDark)"/>
                </g>
                <g class="ninja-svg__arm-right">
                  <rect x="78" y="47" width="10" height="24" rx="5" fill="url(#ninjaDark)"/>
                </g>
                <g class="ninja-svg__head">
                  <circle cx="60" cy="30" r="17" fill="url(#ninjaSuit)"/>
                  <rect x="47" y="26" width="26" height="9" rx="4.5" fill="#10261a"/>
                  <circle cx="55" cy="30.5" r="1.7" fill="#fff"/>
                  <circle cx="65" cy="30.5" r="1.7" fill="#fff"/>
                </g>
              </g>
            </svg>
          </div>
          <p class="product-page__progress-percent" data-upload-percent>0%</p>
          <div class="product-page__progress-track" aria-hidden="true">
            <div class="product-page__progress-fill" data-upload-fill></div>
          </div>
          <p class="product-page__progress-text">We're making sure your image is perfect for patches. This may take a few seconds.</p>
          <button type="button" class="product-page__progress-stop" data-upload-stop>Stop</button>
        </div>
        <div class="product-page__artwork-review" data-upload-review hidden>
          <div class="product-page__artwork-preview-col">
            <p class="product-page__artwork-top">Hover to Zoom | <span>Click</span> to enlarge</p>
            <p class="product-page__artwork-note">Preview: Design may exceed embroidery detail limits. We may upgrade to Print + Stitch for best results.</p>
            <div class="product-page__artwork-zoom-wrap" data-upload-zoom-wrap>
              <div class="product-page__zoom-pane" data-upload-zoom-pane aria-hidden="true"></div>
              <div class="product-page__artwork-frame" data-upload-zoom-frame>
                <div class="product-page__dim-guide product-page__dim-guide--top" aria-hidden="true">
                  <span data-upload-dim-width>2.00"</span>
                </div>
                <div class="product-page__dim-guide product-page__dim-guide--left" aria-hidden="true">
                  <span data-upload-dim-height>2.19"</span>
                </div>
                <img src="" alt="Uploaded design preview" class="product-page__artwork-img" data-upload-preview-image>
              </div>
            </div>
            <div class="product-page__artwork-tools">
              <button type="button" data-upload-crop>Crop &amp; Trim</button>
              <button
                type="button"
                class="product-page__toggle-btn"
                data-upload-remove-bg
                aria-pressed="false"
              >
                <span>Remove Background</span>
                <span class="product-page__toggle-switch" aria-hidden="true"></span>
              </button>
              <button type="button" data-upload-delete>Delete image</button>
            </div>
          </div>
          <div class="product-page__tier-col">
            <h3>Buy More. Save More.</h3>
            <table class="product-page__tier-table" aria-label="Quantity discount table">
              <thead>
                <tr>
                  <th>Quantity</th>
                  <th>Price</th>
                  <th>Qty Discount</th>
                </tr>
              </thead>
              <tbody data-tier-body>
                <tr class="is-active">
                  <td>10+</td>
                  <td>$6.71 ea</td>
                  <td>-</td>
                </tr>
              </tbody>
            </table>
            <button type="button" class="product-page__change-file" data-upload-change>Change uploaded file</button>
          </div>
        </div>
        <div
          class="product-page__sizer"
          data-patch-sizer
          data-pricing-url="{{ 'pricing.json' | asset_url }}"
          data-product-name="{{ product.title | strip | escape }}"
          data-product-type="{{ product.type | strip | escape }}"
          data-product-handle="{{ product.handle | escape }}"
          data-quote-url="{{ section.settings.quote_api_url | escape }}"
          data-ai-generate-url="{{ section.settings.ai_generate_url | escape }}"
          data-ai-status-url="{{ section.settings.ai_status_url | escape }}"
          hidden
        >
          <div class="product-page__sizer-top">
            <h3>Select Your Patch Size:</h3>
            <a href="#" class="product-page__size-guide">Patch Size Guide</a>
          </div>
          <div class="product-page__sizer-grid">
            <div>
              <label>Width (inches)</label>
              <div class="product-page__stepper">
                <button type="button" data-size-dec="width">−</button>
                <input type="number" step="0.01" min="1" value="2" data-size-width name="properties[Patch Width (in)]">
                <button type="button" data-size-inc="width">+</button>
              </div>
            </div>
            <div>
              <label>Height (inches)</label>
              <div class="product-page__stepper">
                <button type="button" data-size-dec="height">−</button>
                <input type="number" step="0.01" min="1" value="2.19" data-size-height name="properties[Patch Height (in)]">
                <button type="button" data-size-inc="height">+</button>
              </div>
            </div>
            <div>
              <label>Price</label>
              <p class="product-page__sizer-price"><span data-size-price>$6.71</span><small>ea.</small></p>
            </div>
            <div>
              <label for="Quantity">Qty</label>
              <input id="Quantity" class="product-page__qty" type="number" name="quantity" min="10" value="10" data-size-qty>
              <p class="product-page__sizer-min">10 Piece Min</p>
            </div>
            <div>
              <label>Total</label>
              <p class="product-page__sizer-total" data-size-total>$67.10</p>
            </div>
          </div>
          <p class="product-page__patch-size">Patch Size <strong data-size-average>2.5"</strong></p>
          <label class="product-page__notes-toggle">
            <input type="checkbox" checked data-notes-toggle>
            Add Free Design Notes (Optional)
          </label>
          <textarea
            class="product-page__notes"
            name="properties[Design Notes]"
            rows="3"
            data-notes-field
            placeholder="i.e. Keep the white inside of the text. Change the border of the logo to blue."
          ></textarea>

          <div class="product-page__options">
            <h3>Select Your Options Below</h3>
            <p class="product-page__options-sub">These do not affect your final price.</p>

            <div class="product-page__option-group" data-option-group="shape">
              <p class="product-page__option-title">Select Shape: <strong data-option-selected-label>Circle</strong></p>
              <input type="hidden" name="properties[Shape]" value="Circle" data-option-hidden>
              <div class="product-page__option-grid">
                <button type="button" class="product-page__option-card is-active" data-option-value="Circle">
                  <span class="product-page__option-thumb">◯</span><span>Circle</span>
                </button>
                <button type="button" class="product-page__option-card" data-option-value="Square">
                  <span class="product-page__option-thumb">▢</span><span>Square</span>
                </button>
                <button type="button" class="product-page__option-card" data-option-value="Rectangle">
                  <span class="product-page__option-thumb">▭</span><span>Rectangle</span>
                </button>
                <button type="button" class="product-page__option-card" data-option-value="Oval">
                  <span class="product-page__option-thumb">⬭</span><span>Oval</span>
                </button>
                <button type="button" class="product-page__option-card" data-option-value="Custom Shape">
                  <span class="product-page__option-thumb">✦</span><span>Custom Shape</span>
                </button>
              </div>
            </div>

            <div class="product-page__option-group">
              <p class="product-page__option-title">Patch Background Color:</p>
              <input type="text" class="product-page__option-input" name="properties[Patch Background Color]" placeholder="e.g. White">
            </div>

            <div class="product-page__option-group" data-option-group="border">
              <p class="product-page__option-title">Border Style Circle: <strong data-option-selected-label>Embroidered / Hot Cut (Most Popular)</strong></p>
              <input type="hidden" name="properties[Border Style]" value="Embroidered / Hot Cut (Most Popular)" data-option-hidden>
              <div class="product-page__option-grid product-page__option-grid--small">
                <button type="button" class="product-page__option-card is-active" data-option-value="Embroidered / Hot Cut (Most Popular)">
                  <span class="product-page__option-thumb">▨</span><span>Embroidered</span>
                </button>
                <button type="button" class="product-page__option-card" data-option-value="Merrowed Border">
                  <span class="product-page__option-thumb">◫</span><span>Merrowed</span>
                </button>
              </div>
            </div>

            <div class="product-page__option-group">
              <p class="product-page__option-title">Border Thread Color:</p>
              <input type="text" class="product-page__option-input" name="properties[Border Thread Color]" placeholder="e.g. Gold">
            </div>

            <div class="product-page__option-group" data-option-group="backing">
              <p class="product-page__option-title">Select Your Backing: <strong data-option-selected-label>Heat Applied (Most Popular)</strong></p>
              <input type="hidden" name="properties[Backing]" value="Heat Applied (Most Popular)" data-option-hidden>
              <div class="product-page__option-grid product-page__option-grid--small">
                <button type="button" class="product-page__option-card is-active" data-option-value="Heat Applied (Most Popular)">
                  <span class="product-page__option-thumb">⬒</span><span>Heat Applied</span>
                </button>
                <button type="button" class="product-page__option-card" data-option-value="Peel & Stick">
                  <span class="product-page__option-thumb">◩</span><span>Peel & Stick</span>
                </button>
                <button type="button" class="product-page__option-card" data-option-value="Velcro">
                  <span class="product-page__option-thumb">▧</span><span>Velcro</span>
                </button>
              </div>
              <p class="product-page__options-desc">Our most popular method allows you to quickly and conveniently use a heat press or even a home iron if the right pressure and heat are applied.</p>
            </div>
          </div>
        </div>
        <input type="hidden" name="return_to" value="/cart">
        <div class="product-page__checkout-wrap" data-checkout-wrap hidden>
          <button
            type="submit"
            class="product-page__checkout-btn"
            {% if checkout_variant == blank or checkout_variant.available == false %}disabled{% endif %}
          >
            {% if checkout_variant and checkout_variant.available %}
              PROCEED TO CHECKOUT
            {% else %}
              SOLD OUT
            {% endif %}
          </button>
        </div>
      {% endform %}
      {% else %}
        <div class="product-page__soldout-banner">
          This product is currently sold out. Please choose another patch type or restock this item in Shopify admin.
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {
      "type": "text",
      "id": "quote_api_url",
      "label": "Quote API URL",
      "info": "Example: https://your-backend.com/api/quote"
    },
    {
      "type": "text",
      "id": "ai_generate_url",
      "label": "AI Generate URL (Shopify app)",
      "info": "Example: https://your-app.com/api/ai/generate"
    },
    {
      "type": "text",
      "id": "ai_status_url",
      "label": "AI Status URL base (Shopify app)",
      "info": "Example: https://your-app.com/api/ai/generate"
    }
  ]
}
{% endschema %}
