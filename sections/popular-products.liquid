<section class="shop-types popular-products section-{{ section.id }}">
  <div class="shop-types__inner">
    {% if section.settings.heading != blank %}
      <h2 class="shop-types__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    {% if section.settings.collection != blank and section.settings.collection.all_products_count > 0 %}
      <div class="shop-types__grid">
        {% for product in section.settings.collection.products limit: section.settings.products_to_show %}
          <article class="shop-types__card">
            <a class="shop-types__media-link" href="{{ product.url }}">
              <div class="shop-types__media">
                {% if product.featured_image %}
                  {% assign img_alt = product.featured_image.alt | default: product.title %}
                  {{
                    product.featured_image
                    | image_url: width: 600
                    | image_tag: loading: 'lazy', class: 'shop-types__img', widths: '300, 450, 600', sizes: '(min-width: 990px) 22vw, 50vw', alt: img_alt
                  }}
                {% else %}
                  <div class="shop-types__ph" aria-hidden="true"></div>
                {% endif %}
              </div>
            </a>
            <div class="shop-types__content">
              <h3 class="shop-types__title">
                <a href="{{ product.url }}">{{ product.title | escape }}</a>
              </h3>
              <p class="shop-types__price-line">As low as {{ product.price | money }} ea.</p>
              <a class="shop-types__btn" href="{{ product.url }}">{{ section.settings.button_label | escape }}</a>
            </div>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <div class="shop-types__grid shop-types__grid--placeholder" role="list">
        {% for i in (1..4) %}
          <div class="shop-types__card shop-types__card--dummy" role="listitem">
            <div class="shop-types__media-link">
              <div class="shop-types__media">
                <div class="shop-types__ph" aria-hidden="true"></div>
              </div>
            </div>
            <div class="shop-types__content">
              <h3 class="shop-types__title">Popular product {{ i }}</h3>
              <p class="shop-types__price-line">As low as $1.84 ea.</p>
              <span class="shop-types__btn">{{ section.settings.button_label | escape }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Popular products",
  "tag": "section",
  "class": "section-popular-products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop Other Popular Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 8,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Customize"
    }
  ],
  "presets": [
    {
      "name": "Popular products"
    }
  ]
}
{% endschema %}
