<section class="commercial-video section-{{ section.id }}">
  <div class="commercial-video__inner">
    <div class="commercial-video__media">
      {% if section.settings.video != blank %}
        {{
          section.settings.video
          | video_tag:
            controls: true,
            autoplay: false,
            loop: false,
            muted: false,
            class: 'commercial-video__player'
        }}
      {% elsif section.settings.video_url != blank %}
        <div class="commercial-video__embed-wrap">
          <iframe
            class="commercial-video__embed"
            src="{{ section.settings.video_url | escape }}"
            title="{{ section.settings.heading | escape }}"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      {% else %}
        <div class="commercial-video__placeholder" aria-hidden="true"></div>
      {% endif %}
    </div>

    <div class="commercial-video__content">
      {% if section.settings.heading != blank %}
        <h2 class="commercial-video__title">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="commercial-video__text rte">{{ section.settings.text }}</div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Commercial video",
  "tag": "section",
  "class": "section-commercial-video",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Upload video"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Embed URL (YouTube/Vimeo)",
      "info": "Used when no uploaded video is selected."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Watch our Commercial"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Fineyst Patches is the home of all your favorite patch types and more!<br>Let's get Patchin' Crazy!</p>"
    }
  ],
  "presets": [
    {
      "name": "Commercial video"
    }
  ]
}
{% endschema %}
