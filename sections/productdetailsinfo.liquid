<section class="product-details-info section-{{ section.id }}">
  <div class="product-details-info__inner">
    <div class="product-details-info__content">
      {% if section.settings.heading != blank %}
        <h2 class="product-details-info__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.body != blank %}
        <div class="product-details-info__body rte">{{ section.settings.body }}</div>
      {% endif %}
    </div>

    <div class="product-details-info__faq-wrap">
      <h3 class="product-details-info__faq-heading">FAQ</h3>
      <div class="product-details-info__accordion">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            <details class="product-details-info__item" {{ block.shopify_attributes }}>
              <summary class="product-details-info__summary">
                <span>{{ block.settings.title | escape }}</span>
                <span class="product-details-info__icon" aria-hidden="true"></span>
              </summary>
              {% if block.settings.content != blank %}
                <div class="product-details-info__panel rte">
                  {{ block.settings.content }}
                </div>
              {% endif %}
            </details>
          {% endfor %}
        {% else %}
          {% assign fallback_titles = 'Features|Satisfaction Guarantee|Pressing Instructions|Art Upload Recommendations|Care Instructions|Order Issues & Reprints|Shipping' | split: '|' %}
          {% for title in fallback_titles %}
            <details class="product-details-info__item">
              <summary class="product-details-info__summary">
                <span>{{ title }}</span>
                <span class="product-details-info__icon" aria-hidden="true"></span>
              </summary>
            </details>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product details info",
  "tag": "section",
  "class": "section-product-details-info",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product Details"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Embroidered patches from Ninja Patches offer a vibrant and professional way to feature designs on apparel such as clothing, hats, jackets, or backpacks. Crafted from durable materials with precise embroidery, these custom patches ensure strong and long-lasting adherence to your chosen item.</p><p>Want Embroidery, but your design may be too detailed or intricate? No worries, we will simply upgrade you to our Print + Stitch method which include embroidery and our sublimated print for the finer details of your design.</p>"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Accordion item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Features"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Add content for this item.</p>"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Product details info",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "title": "Features"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Satisfaction Guarantee"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Pressing Instructions"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Art Upload Recommendations"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Care Instructions"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Order Issues & Reprints"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Shipping"
          }
        }
      ]
    }
  ]
}
{% endschema %}
