<section class="shop-types section-{{ section.id }}">
  <div class="shop-types__inner">
    {% if section.settings.heading != blank %}
      <h2 class="shop-types__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    {% if section.settings.collection != blank and section.settings.collection.all_products_count > 0 %}
      <div class="shop-types__grid">
        {% for product in section.settings.collection.products limit: section.settings.products_to_show %}
          <a class="shop-types__card" href="{{ product.url }}">
            <div class="shop-types__media">
              {% if product.featured_image %}
                {% assign img_alt = product.featured_image.alt | default: product.title %}
                {{
                  product.featured_image
                  | image_url: width: 600
                  | image_tag: loading: 'lazy', class: 'shop-types__img', widths: '300, 450, 600', sizes: '(min-width: 990px) 22vw, 50vw', alt: img_alt
                }}
              {% else %}
                <div class="shop-types__ph" aria-hidden="true"></div>
              {% endif %}
            </div>
            <span class="shop-types__title">{{ product.title | escape }}</span>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <div class="shop-types__grid shop-types__grid--placeholder" role="list">
        {% for i in (1..4) %}
          <div class="shop-types__card shop-types__card--dummy" role="listitem">
            <div class="shop-types__ph" aria-hidden="true"></div>
            <span class="shop-types__title">Patch type {{ i }}</span>
            <p class="shop-types__hint">Choose a collection in the theme editor to populate this grid.</p>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.shop_patch_types.name",
  "tag": "section",
  "class": "section-shop-patch-types",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop All Patch Types"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "t:sections.shop_patch_types.name"
    }
  ]
}
{% endschema %}
