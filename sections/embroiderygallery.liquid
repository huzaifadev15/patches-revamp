<section class="embroidery-gallery section-{{ section.id }}">
  <div class="embroidery-gallery__inner">
    {% if section.settings.heading != blank %}
      <h2 class="embroidery-gallery__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    <div class="embroidery-gallery__grid">
      <div class="embroidery-gallery__main">
        {% if section.settings.main_image != blank %}
          {% assign main_alt = section.settings.main_image.alt | default: section.settings.heading %}
          {{
            section.settings.main_image
            | image_url: width: 1200
            | image_tag: loading: 'lazy', class: 'embroidery-gallery__img', widths: '640, 900, 1200', sizes: '(min-width: 990px) 42vw, 100vw', alt: main_alt
          }}
        {% else %}
          <div class="embroidery-gallery__ph" aria-hidden="true"></div>
        {% endif %}
      </div>

      <div class="embroidery-gallery__thumbs">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            <div class="embroidery-gallery__thumb" {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}
                {% assign thumb_alt = block.settings.image.alt | default: section.settings.heading %}
                {{
                  block.settings.image
                  | image_url: width: 520
                  | image_tag: loading: 'lazy', class: 'embroidery-gallery__img', widths: '260, 380, 520', sizes: '(min-width: 990px) 19vw, 50vw', alt: thumb_alt
                }}
              {% else %}
                <div class="embroidery-gallery__ph" aria-hidden="true"></div>
              {% endif %}
            </div>
          {% endfor %}
        {% else %}
          {% for i in (1..6) %}
            <div class="embroidery-gallery__thumb">
              <div class="embroidery-gallery__ph" aria-hidden="true"></div>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Embroidery gallery",
  "tag": "section",
  "class": "section-embroidery-gallery",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Leader in Custom Embroidered Patches"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main large image"
    }
  ],
  "blocks": [
    {
      "type": "thumb",
      "name": "Thumbnail image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Embroidery gallery",
      "blocks": [
        { "type": "thumb" },
        { "type": "thumb" },
        { "type": "thumb" },
        { "type": "thumb" },
        { "type": "thumb" },
        { "type": "thumb" }
      ]
    }
  ]
}
{% endschema %}
