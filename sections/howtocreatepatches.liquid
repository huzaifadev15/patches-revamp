<section class="how-create-patches section-{{ section.id }}">
  <div class="how-create-patches__inner">
    <div class="how-create-patches__content">
      {% if section.settings.heading != blank %}
        <h2 class="how-create-patches__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.intro != blank %}
        <p class="how-create-patches__intro">{{ section.settings.intro | escape }}</p>
      {% endif %}

      {% for block in section.blocks %}
        <article class="how-create-patches__point" {{ block.shopify_attributes }}>
          {% if block.settings.title != blank %}
            <h3 class="how-create-patches__point-title">{{ block.settings.title | escape }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <p class="how-create-patches__point-text">{{ block.settings.text | escape }}</p>
          {% endif %}
        </article>
      {% endfor %}
    </div>

    <div class="how-create-patches__media">
      <div class="how-create-patches__grid">
        <div class="how-create-patches__tile how-create-patches__tile--one">
          {% if section.settings.image_1 != blank %}
            {{
              section.settings.image_1
              | image_url: width: 700
              | image_tag: loading: 'lazy', class: 'how-create-patches__img', widths: '260, 420, 700', sizes: '(min-width: 990px) 24vw, 60vw', alt: section.settings.heading
            }}
          {% else %}
            <div class="how-create-patches__ph" aria-hidden="true"></div>
          {% endif %}
        </div>
        <div class="how-create-patches__tile how-create-patches__tile--two">
          {% if section.settings.image_2 != blank %}
            {{
              section.settings.image_2
              | image_url: width: 520
              | image_tag: loading: 'lazy', class: 'how-create-patches__img', widths: '220, 340, 520', sizes: '(min-width: 990px) 12vw, 40vw', alt: section.settings.heading
            }}
          {% else %}
            <div class="how-create-patches__ph" aria-hidden="true"></div>
          {% endif %}
        </div>
        <div class="how-create-patches__tile how-create-patches__tile--three">
          {% if section.settings.image_3 != blank %}
            {{
              section.settings.image_3
              | image_url: width: 600
              | image_tag: loading: 'lazy', class: 'how-create-patches__img', widths: '220, 340, 600', sizes: '(min-width: 990px) 14vw, 44vw', alt: section.settings.heading
            }}
          {% else %}
            <div class="how-create-patches__ph" aria-hidden="true"></div>
          {% endif %}
        </div>
        <div class="how-create-patches__tile how-create-patches__tile--four">
          {% if section.settings.image_4 != blank %}
            {{
              section.settings.image_4
              | image_url: width: 700
              | image_tag: loading: 'lazy', class: 'how-create-patches__img', widths: '260, 420, 700', sizes: '(min-width: 990px) 24vw, 60vw', alt: section.settings.heading
            }}
          {% else %}
            <div class="how-create-patches__ph" aria-hidden="true"></div>
          {% endif %}
        </div>
        <div class="how-create-patches__tile how-create-patches__tile--five">
          {% if section.settings.image_5 != blank %}
            {{
              section.settings.image_5
              | image_url: width: 700
              | image_tag: loading: 'lazy', class: 'how-create-patches__img', widths: '260, 420, 700', sizes: '(min-width: 990px) 24vw, 60vw', alt: section.settings.heading
            }}
          {% else %}
            <div class="how-create-patches__ph" aria-hidden="true"></div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How to create patches",
  "tag": "section",
  "class": "section-how-create-patches",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How To Create Your Own Custom Patches"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Creating custom patches has never been easier. Simply choose your style, upload your file, select your shape and size, and checkout."
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Top left image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Top middle image"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Top right image"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Bottom left image"
    },
    {
      "type": "image_picker",
      "id": "image_5",
      "label": "Bottom right image"
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Content point",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Versatile Uses for Custom Patches"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Custom patches can elevate uniforms, merchandise, and personal apparel with durable, eye-catching branding."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "How to create patches",
      "blocks": [
        {
          "type": "point",
          "settings": {
            "title": "Versatile Uses for Custom Patches",
            "text": "Custom patches are useful for branding uniforms and promoting causes while adding decorative flair to jackets, hats, bags, and more."
          }
        },
        {
          "type": "point",
          "settings": {
            "title": "Easy Application Without Sewing",
            "text": "Our embroidered patches are simple to apply with a heat press and medium-firm pressure in seconds."
          }
        },
        {
          "type": "point",
          "settings": {
            "title": "Choosing the Right Patch Type",
            "text": "Choose from embroidered, printed, leather, and chenille options depending on your use case."
          }
        },
        {
          "type": "point",
          "settings": {
            "title": "Production You Can Trust",
            "text": "Each patch is reviewed for quality so your final product looks sharp and lasts."
          }
        }
      ]
    }
  ]
}
{% endschema %}
